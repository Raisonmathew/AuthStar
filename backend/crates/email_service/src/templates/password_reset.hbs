{{#> base_layout}}
<h2>Reset Your Password</h2>
<p>We received a request to reset your password. Click the button below to create a new password:</p>

<div style="text-align: center;">
    <a href="{{reset_link}}" class="button">Reset Password</a>
</div>

<p class="muted">This link will expire in {{expires_in}}.</p>

<div class="info-box">
    <p style="margin: 0;"><strong>Didn't request this?</strong></p>
    <p style="margin: 8px 0 0 0;">If you didn't request a password reset, you can safely ignore this email. Your
        password will remain unchanged.</p>
</div>

<p class="muted">If the button doesn't work, copy and paste this link into your browser:</p>
<p class="muted" style="word-break: break-all;">{{reset_link}}</p>
{{/base_layout}}