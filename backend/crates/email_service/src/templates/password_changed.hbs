{{#> base_layout}}
<h2>Password Changed</h2>
<p>Your password was successfully changed on {{time}}.</p>

<div class="info-box">
    <p style="margin: 0;">If you made this change, no further action is needed.</p>
</div>

<div class="warning-box">
    <p style="margin: 0;"><strong>Didn't make this change?</strong></p>
    <p style="margin: 8px 0 0 0;">If you didn't change your password, your account may be compromised. Please contact
        our support team immediately.</p>
</div>
{{/base_layout}}