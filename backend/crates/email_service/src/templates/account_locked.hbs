{{#> base_layout}}
<h2>Account Locked</h2>
<p>Your account has been temporarily locked for security reasons.</p>

<div class="warning-box">
    <p style="margin: 0;"><strong>Reason:</strong> {{reason}}</p>
</div>

<p>To regain access to your account, click the button below:</p>

<div style="text-align: center;">
    <a href="{{unlock_link}}" class="button">Unlock Account</a>
</div>

<p class="muted">If you did not attempt to access your account, we recommend changing your password immediately after
    unlocking.</p>

<p class="muted">If the button doesn't work, copy and paste this link into your browser:</p>
<p class="muted" style="word-break: break-all;">{{unlock_link}}</p>
{{/base_layout}}