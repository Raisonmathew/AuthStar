  "query": "\n        SELECT id, user_id, tenant_id, key_hash, scopes, revoked_at, expires_at\n        FROM api_keys\n        WHERE key_prefix = $1\n          AND revoked_at IS NULL\n          AND (expires_at IS NULL OR expires_at > NOW())\n        ",
