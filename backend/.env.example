# Environment (set to "production" to enforce strict CORS, HTTPS cookies, etc.)
# APP_ENV=development
# ENVIRONMENT=development

# Test seed bypass token. Required to call /api/test/* endpoints (which only
# exist in non-production builds). Sent by Playwright as `X-Test-Seed-Token`
# and matched constant-time in CSRF middleware. Leave unset in production —
# without it the bypass is disabled and CSRF rejects all /api/test/* calls.
TEST_SEED_TOKEN=dev-test-seed-token-change-for-staging

# Database
DATABASE_URL=postgres://idaas_user:password@localhost:5432/idaas
# ROOT_DATABASE_URL=postgres://postgres:password@localhost:5432/postgres

# Database pool tuning (defaults are fine for dev)
# DB_MAX_CONNECTIONS=10
# DB_MIN_CONNECTIONS=1
# DB_ACQUIRE_TIMEOUT_SECS=30

# Read replicas (production only)
# DB_ENABLE_READ_REPLICAS=false
# DATABASE_READ_REPLICA_URLS=postgres://reader:password@replica1:5432/idaas,postgres://reader:password@replica2:5432/idaas
# DB_MAX_CONNECTIONS_PER_REPLICA=5

# PgBouncer (production only)
# USE_PGBOUNCER=false
# PGBOUNCER_URL=postgres://idaas_user:password@localhost:6432/idaas

# Redis Configuration
# Mode: standalone, sentinel, or cluster
REDIS_MODE=standalone

# Standalone mode (default)
REDIS_URL=redis://localhost:6379

# Sentinel mode (high availability)
# Comma-separated list of sentinel addresses
# REDIS_SENTINEL_URLS=redis://localhost:26379,redis://localhost:26380,redis://localhost:26381
# REDIS_MASTER_NAME=mymaster
# REDIS_SENTINEL_PASSWORD=
# REDIS_PASSWORD=

# Cluster mode (future)
# REDIS_CLUSTER_URLS=redis://node1:6379,redis://node2:6379,redis://node3:6379

# Connection settings
REDIS_MAX_CONNECTIONS=10
REDIS_MIN_IDLE=2
REDIS_CONNECTION_TIMEOUT_MS=5000
REDIS_COMMAND_TIMEOUT_MS=3000
# REDIS_RESPONSE_TIMEOUT_MS=3000
# REDIS_DB=0
# REDIS_URLS=redis://node1:6379,redis://node2:6379

# Server
HOST=0.0.0.0
PORT=3000
RUST_LOG=info,api_server=debug

# Audit overflow queue
# Local default is fine for development. In production, point this to a
# persistent volume so overflowed audit records survive restarts.
AUDIT_OVERFLOW_PATH=./audit_overflow

# JWT Keys (ES256)
# Generate with: openssl ecparam -genkey -name prime256v1 -noout -out private.pem
# Extract public: openssl ec -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END EC PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----
JWT_EXPIRATION_SECONDS=60
JWT_ISSUER=https://auth.yourdomain.com
JWT_AUDIENCE=https://api.yourdomain.com

# Session cookie
SESSION_COOKIE_NAME=__session
SESSION_COOKIE_DOMAIN=localhost
SESSION_COOKIE_SECURE=false
SESSION_EXPIRATION_DAYS=30

# OAuth Providers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/v1/oauth/google/callback

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:3000/v1/oauth/github/callback

MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3000/v1/oauth/microsoft/callback

# Email Service (SendGrid — production)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=IDaaS Platform

# Email Service (SMTP — for development use MailHog on localhost:1025)
# When SMTP_HOST is set it takes precedence over SendGrid.
# docker run -d -p 8025:8025 -p 1025:1025 mailhog/mailhog
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_TLS=false
# SMTP_USERNAME=
# SMTP_PASSWORD=

# SMS Service (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Frontend
FRONTEND_URL=http://localhost:5173

# CORS (comma-separated origins, empty = allow all for dev)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# WebAuthn / Passkeys
# RP ID must match the domain where passkeys are registered.
# Origin must use HTTPS in production.
PASSKEY_RP_ID=localhost
PASSKEY_ORIGIN=http://localhost:3000

# EIAA Capsule Compiler
# Base64-encoded Ed25519 secret key for capsule signing.
# Generate: openssl genpkey -algorithm ed25519 | openssl pkey -outform DER | base64
# WARNING: If not set, ephemeral keys are used — attestations won't survive restarts.
COMPILER_SK_B64=
RUNTIME_GRPC_ADDR=http://127.0.0.1:50061
# RUNTIME_GRPC_ENDPOINTS=http://127.0.0.1:50061,http://127.0.0.1:50062
# RUNTIME_LISTEN_ADDR=0.0.0.0:50061
# RUNTIME_DATABASE_URL=postgres://idaas_user:password@localhost:5432/idaas
# RUNTIME_COMPILER_PK_B64=

# EIAA nonce lifetime (seconds, default 300)
# NONCE_TTL_SECONDS=300

# IP Intelligence (optional, free tier)
IPLOCATE_API_KEY=
IPLOCATE_ENABLED=true
# IPLOCATE_API_URL=https://www.iplocate.io/api/lookup

# Have I Been Pwned — password breach checking (free, no key needed for basic use)
# HIBP_ENABLED=true

# Rate Limiting
RATE_LIMIT_PER_SECOND=10
RATE_LIMIT_BURST=20

# File Storage (S3 compatible)
S3_BUCKET=idaas-assets
S3_REGION=us-east-1
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_ENDPOINT=https://s3.amazonaws.com

# Encryption key for sensitive data (32-byte hex)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# TOTP factor secret encryption (32-byte hex key for AES-256-GCM)
# If not set, TOTP secrets are stored in plaintext (insecure for production).
# Generate: openssl rand -hex 32
FACTOR_ENCRYPTION_KEY=

# OAuth token encryption (32-byte hex)
# Generate: openssl rand -hex 32
OAUTH_TOKEN_ENCRYPTION_KEY=

# SSO connection secrets encryption (32-byte hex)
# Generate: openssl rand -hex 32
SSO_ENCRYPTION_KEY=

# SAML Service Provider
SAML_CLOCK_SKEW_SECONDS=60
# SAML_ACS_URL=https://auth.yourdomain.com/v1/saml/acs
# SAML_SP_ENTITY_ID=https://auth.yourdomain.com
# SAML_SP_SIGNING_KEY_PEM=
# SAML_SP_SIGNING_CERT_PEM=

# Bootstrap admin password (only used on first run to seed the system admin)
# Generate a strong password. If unset, no admin password is created.
# IDAAS_BOOTSTRAP_PASSWORD=

# Signup flow
# REQUIRE_EMAIL_VERIFICATION=true

# OpenTelemetry (production observability)
# OTEL_SDK_DISABLED=false
# OTEL_SERVICE_NAME=idaas-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_TRACES_SAMPLER_ARG=1.0
